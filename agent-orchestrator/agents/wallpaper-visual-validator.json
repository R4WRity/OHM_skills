{
  "agent_id": "wallpaper-visual-validator",
  "name": "Wallpaper Visual Validator",
  "description": "Validates wallpaper dashboard is showing real data from Neo4j (not mock data). Detects bridge failures and triggers auto-recovery.",
  "version": "1.0.0",
  "enabled": true,
  "infrastructure": "permanent",
  "model": {
    "provider": "ollama",
    "model": "gemma3:1b",
    "fallback": "ollama/qwen3:1b",
    "max_tokens": 4096,
    "temperature": 0.2
  },
  "resources": {
    "max_vram_mb": 1500,
    "timeout_seconds": 180,
    "retry_attempts": 3,
    "retry_delay_seconds": 5
  },
  "schedule": {
    "enabled": true,
    "cron": "*/10 * * * *",
    "timezone": "America/Los_Angeles",
    "max_runtime_seconds": 300
  },
  "prompt_template": "skills/agent-orchestrator/prompts/wallpaper-visual-validator.txt",
  "environment": {
    "BRIDGE_URL": "http://localhost:8080",
    "WALLPAPER_URL": "http://localhost:8889/index.html",
    "BROWSER_MCP_URL": "http://localhost:9102",
    "BRIDGE_SCRIPT": "projects/wallpapers/dataviz/retro-terminal/bridge_server.py",
    "RESTART_COMMAND": "python skills/diagnostics/scripts/reset_wallpaper.ps1"
  },
  "health_checks": {
    "enabled": true,
    "interval_seconds": 60,
    "max_unhealthy_count": 3,
    "auto_restart": true
  },
  "actions": {
    "can_restart_bridge": true,
    "can_restart_wallpaper": false,
    "can_notify_discord": true,
    "max_restarts_per_hour": 5
  },
  "dependencies": [
    "notion-diagnostics"
  ],
  "created_at": "2026-03-03T14:30:00Z",
  "updated_at": "2026-03-03T14:30:00Z"
}
